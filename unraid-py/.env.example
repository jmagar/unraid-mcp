# Unraid MCP Server Configuration
# =================================

# Core API Configuration (Required)
# ---------------------------------
UNRAID_API_KEY=your_api_key
UNRAID_API_URL=http://your-unraid-server

# MCP Server Settings
# -------------------
# Default transport is streamable-http (v1.2.0+).
# Use stdio for Claude Desktop / local process-based clients.
# Options: streamable-http (default), stdio, sse (deprecated; removed in v3.0.0)
UNRAID_MCP_HOST=0.0.0.0
UNRAID_MCP_PORT=6970
UNRAID_MCP_TRANSPORT=streamable-http

# Max serialized tool-response size in bytes. Responses over the cap are replaced
# with a parseable JSON truncation marker (not hard-cut mid-JSON).
# Default 40000 (~40 KB ≈ 10K tokens).
UNRAID_MCP_MAX_RESPONSE_BYTES=40000

# HTTP Bearer Token Authentication (streamable-http / sse transports)
# -------------------------------------------------------------------
# Generate a token and paste it here AND into the plugin's userConfig field:
#   openssl rand -hex 32
# Required when UNRAID_MCP_TRANSPORT is not "stdio" and UNRAID_MCP_DISABLE_HTTP_AUTH is not "true".
UNRAID_MCP_BEARER_TOKEN=your_bearer_token

# Safety flags
# ------------
UNRAID_MCP_DISABLE_HTTP_AUTH=false

# When UNRAID_MCP_DISABLE_HTTP_AUTH=true AND the server binds to a non-loopback
# interface (i.e. UNRAID_MCP_HOST is not 127.0.0.1/::1/localhost), the server REFUSES
# to start unless this is set to true. Setting it affirms that a trusted reverse proxy
# (e.g. SWAG) fronts this server and enforces authentication — without it, an
# unauthenticated MCP endpoint would be exposed to the network.
UNRAID_MCP_TRUST_PROXY=false

# Google OAuth Authentication (OPTIONAL — alternative to the bearer token)
# ------------------------------------------------------------------------
# When BOTH client id and secret are set, HTTP authentication is delegated to
# Google OAuth (FastMCP's GoogleProvider). Leave these unset (the default) to
# keep bearer-token auth. MCP clients then authenticate with the standard OAuth
# browser flow.
#
# Coexistence: if UNRAID_MCP_BEARER_TOKEN is ALSO set while OAuth is enabled,
# the static token remains valid alongside OAuth tokens (checked in constant
# time before Google verification). The token is never auto-generated in OAuth
# mode — setting it explicitly is the opt-in for running both.
#
# Setup: create an OAuth 2.0 "Web application" client in Google Cloud Console,
# add "<UNRAID_MCP_GOOGLE_BASE_URL>/auth/callback" as an Authorized redirect URI.
# See https://gofastmcp.com/integrations/google
#
# UNRAID_MCP_GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
# UNRAID_MCP_GOOGLE_CLIENT_SECRET=GOCSPX-...
# Public base URL of THIS server (must match the Google redirect URI host). Required.
# UNRAID_MCP_GOOGLE_BASE_URL=https://unraid-mcp.example.com
# Optional: comma/space-separated scopes (default: openid + userinfo.email).
# UNRAID_MCP_GOOGLE_REQUIRED_SCOPES=openid https://www.googleapis.com/auth/userinfo.email
# REQUIRED authorization allowlist (unless explicitly allowing any Google user).
# OAuth proves identity; this controls which Google identities may use the MCP server.
# UNRAID_MCP_GOOGLE_ALLOWED_EMAILS=you@example.com admin@example.com
# UNRAID_MCP_GOOGLE_ALLOWED_DOMAINS=example.com
# DANGEROUS: only for private/trusted deployments where any Google account is acceptable.
# UNRAID_MCP_GOOGLE_ALLOW_ANY_USER=false
# Optional: OAuth callback path (default: /auth/callback). Must match Google config.
# UNRAID_MCP_GOOGLE_REDIRECT_PATH=/auth/callback
#
# Optional token persistence (survive restarts, NO Redis required). Set BOTH keys
# to store tokens encrypted-at-rest on disk via a FileTreeStore; set NEITHER to
# keep tokens in memory (cleared on restart). Setting only one is a config error.
#   Generate the encryption key:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# UNRAID_MCP_GOOGLE_JWT_SIGNING_KEY=your_jwt_signing_secret
# UNRAID_MCP_GOOGLE_ENCRYPTION_KEY=your_fernet_key
# Optional: directory for persisted encrypted tokens (default ~/.unraid-mcp/oauth-tokens).
# UNRAID_MCP_GOOGLE_STORAGE_DIR=/path/to/oauth-tokens

# TLS / SSL Verification
# ----------------------
# UNRAID_VERIFY_SSL controls verification of the Unraid API's TLS certificate.
#   true  (default) — verify the certificate (recommended).
#   /path/to/ca.pem — trust a self-signed cert via a CA bundle WITHOUT disabling
#                     verification. This is the recommended way to handle self-signed certs.
#   false           — DISABLE verification entirely (DANGEROUS).
# Disabling verification sends the API key to an unverified peer over BOTH the HTTP
# GraphQL client AND the WebSocket subscription connection, exposing it to
# man-in-the-middle interception. Because it is dangerous, UNRAID_VERIFY_SSL=false
# additionally requires UNRAID_ALLOW_INSECURE_TLS=true or the server refuses to start.
UNRAID_VERIFY_SSL=true
# Second, explicit opt-in required to actually disable TLS verification (see above).
UNRAID_ALLOW_INSECURE_TLS=false

# Logging
# -------
# UNRAID_MCP_LOG_LEVEL: DEBUG, INFO (default), WARNING, ERROR, CRITICAL.
#   Avoid DEBUG in production — it may log GraphQL variable values; redaction is best-effort.
# UNRAID_MCP_LOG_FILE: log filename inside the logs/ directory.
UNRAID_MCP_LOG_LEVEL=INFO
UNRAID_MCP_LOG_FILE=unraid-mcp.log

# Subscriptions (live WebSocket data)
# -----------------------------------
# UNRAID_AUTO_START_SUBSCRIPTIONS: lazily initialize enabled subscriptions on the first
#   MCP resource or subscription-diagnostic access (default true). The first read may
#   return a connecting response while the cache warms.
# UNRAID_MAX_RECONNECT_ATTEMPTS:   max WebSocket reconnect attempts (default 10).
# UNRAID_AUTOSTART_LOG_PATH:       log file path for the log-tail subscription (auto-detected if unset).
UNRAID_AUTO_START_SUBSCRIPTIONS=true
UNRAID_MAX_RECONNECT_ATTEMPTS=10
# UNRAID_AUTOSTART_LOG_PATH=/var/log/syslog
# UNRAID_SUBSCRIPTION_MAX_CONNECTIONS: maximum concurrent subscription startup
#   handshakes per process (default 3, range 1..32).
# UNRAID_SUBSCRIPTION_STARTUP_STAGGER_SECONDS: delay between startup launches
#   (default 0.05, range 0..10 seconds).
# Collection mode enforces these limits while streaming, before response shaping:
#   events default 100 (range 1..10000), bytes default 1048576, duration default
#   30 seconds (configuration ceiling 300). The response-size backstop may lower bytes.
UNRAID_SUBSCRIPTION_MAX_CONNECTIONS=3
UNRAID_SUBSCRIPTION_STARTUP_STAGGER_SECONDS=0.05
UNRAID_SUBSCRIPTION_COLLECT_MAX_EVENTS=100
UNRAID_SUBSCRIPTION_COLLECT_MAX_BYTES=1048576
UNRAID_SUBSCRIPTION_COLLECT_MAX_SECONDS=30
# Cached payloads are usable only while subscribed and no older than this many seconds
# (default 300, configurable up to 86400). Per-call WebSocket timeout is capped by
# UNRAID_SUBSCRIPTION_TIMEOUT_MAX_SECONDS (default 60, configurable up to 300).
UNRAID_SUBSCRIPTION_CACHE_MAX_AGE_SECONDS=300
UNRAID_SUBSCRIPTION_TIMEOUT_MAX_SECONDS=60
# UNRAID_MCP_ENABLE_RAW_SUBSCRIPTION_PROBE: include the raw upstream frame in
#   subscriptions/test_query responses (default false). Debug-only and data-sensitive;
#   never enable it on a shared deployment.
UNRAID_MCP_ENABLE_RAW_SUBSCRIPTION_PROBE=false

# Credentials directory override
# ------------------------------
# UNRAID_CREDENTIALS_DIR: override the ~/.unraid-mcp/ credentials directory path.
# UNRAID_CREDENTIALS_DIR=

# Docker user / network
# ---------------------
# DOCKER_NETWORK is optional. If set, the container joins that external network.
# Leave blank (or unset) to use only the default bridge network.
# Create the network first: docker network create <name>
DOCKER_NETWORK=
PGID=1000
PUID=1000
