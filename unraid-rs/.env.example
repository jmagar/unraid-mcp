# unraid-rmcp configuration — example
# Copy to .env and fill in your Unraid server details before running the server.
# This file contains ONLY placeholders — never commit real keys or tokens.

# Unraid GraphQL API (required)
UNRAID_API_URL=https://your-unraid-host/graphql
UNRAID_API_KEY=

# MCP server
UNRAID_RMCP_HOST=0.0.0.0
UNRAID_RMCP_PORT=40010

# MCP server bearer token (generate with: openssl rand -hex 32)
# UNRAID_RMCP_TOKEN=

# Optional: skip TLS verification for self-signed certs (not recommended)
# UNRAID_API_SKIP_TLS_VERIFY=true

# Logging
# RUST_LOG=info

# Docker Compose runtime
PUID=1000
PGID=1000
DOCKER_NETWORK=unrust
