{
  "mcpServers": {
    "unraid-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}",
        "unraid-mcp-server"
      ],
      "env": {
        "UNRAID_MCP_TRANSPORT": "stdio",
        "UV_PROJECT_ENVIRONMENT": "${CLAUDE_PLUGIN_DATA}/.venv"
      }
    }
  }
}
