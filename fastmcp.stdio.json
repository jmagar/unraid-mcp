{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "path": "unraid_mcp/server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": "3.12",
    "editable": ["."]
  },
  "deployment": {
    "transport": "stdio",
    "log_level": "INFO",
    "env": {
      "UNRAID_API_URL": "${UNRAID_API_URL}",
      "UNRAID_API_KEY": "${UNRAID_API_KEY}"
    }
  }
}
