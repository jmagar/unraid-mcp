# unraid-mcp environment variables
# Copy to .env and fill in your values.
#
# UNRAID_*     = Unraid GraphQL API connection settings (secrets)
# UNRAID_MCP_* = MCP server auth settings (secrets + runtime)
#
# Non-secret settings (host, port, auth_mode, etc.) belong in config.toml.

# ── Unraid GraphQL API (required) ─────────────────────────────────────────────

# Full Unraid GraphQL endpoint URL.
# Found in Unraid UI → Settings → Management Access → API.
# Example: https://10-1-0-2.<hash>.myunraid.net:31337/graphql
UNRAID_API_URL=https://your-unraid-host:31337/graphql

# Unraid API key from the Unraid UI.
# Generate at: Unraid UI → Settings → Management Access → API Keys
UNRAID_API_KEY=your_unraid_api_key

# Set to true if your Unraid server uses a self-signed TLS certificate.
# Prefer config.toml [unraid] skip_tls_verify = true for non-secret config.
# UNRAID_API_SKIP_TLS_VERIFY=false

# ── MCP server auth ───────────────────────────────────────────────────────────

# Bearer token for MCP endpoint authentication.
# All requests to /mcp must include: Authorization: Bearer <token>
# Generate with: openssl rand -hex 32  (or: just gen-token)
UNRAID_MCP_TOKEN=your_bearer_token

# Disable MCP auth entirely. Use ONLY behind an upstream gateway/reverse proxy.
# Non-secret; prefer config.toml [mcp] no_auth = true
# UNRAID_MCP_DISABLE_HTTP_AUTH=false

# ── Google OAuth (only when auth_mode = oauth in config.toml) ─────────────────

# Google OAuth client ID. Create at:
#   https://console.cloud.google.com → APIs & Services → Credentials
# Set redirect URI to: ${UNRAID_MCP_PUBLIC_URL}/auth/google/callback
# UNRAID_MCP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google OAuth client secret.
# UNRAID_MCP_GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Docker Compose runtime ────────────────────────────────────────────────────

# Container user/group — set to your host UID/GID so /data volume files
# are owned by you (run: id -u && id -g).
PUID=1000
PGID=1000

# Docker network name (must exist; create with: docker network create jakenet)
DOCKER_NETWORK=jakenet

# Host port for the MCP HTTP server. Container always listens on 6970.
# Override to avoid conflicts: UNRAID_MCP_HOST_PORT=16970
# UNRAID_MCP_HOST_PORT=40010

# Rust log level: trace, debug, info, warn, error
RUST_LOG=info
