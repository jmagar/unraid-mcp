# Unraid MCP Server Configuration
# =================================

# Core API Configuration (Required)
# ---------------------------------
UNRAID_URL=http://your-unraid-server
UNRAID_API_KEY=your_api_key

# MCP Server Settings
# -------------------
# Default transport is streamable-http (v1.2.0+).
# Use stdio for Claude Desktop / local process-based clients.
# Options: streamable-http (default), stdio, sse (deprecated)
UNRAID_MCP_TRANSPORT=http
UNRAID_MCP_PORT=3000

# HTTP Bearer Token Authentication (streamable-http / sse transports)
# -------------------------------------------------------------------
# On first HTTP startup, a secure token is auto-generated, written here,
# and printed once to STDERR.  Copy it into your MCP client config:
#
#   Authorization: Bearer <token>
#
# To pre-set a specific token instead of auto-generating:
UNRAID_MCP_TOKEN=your_bearer_token

# Safety flags
# ------------
NO_AUTH=false
ALLOW_DESTRUCTIVE=false
ALLOW_YOLO=false
