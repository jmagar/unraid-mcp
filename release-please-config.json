{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "python",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "always-update": true,
  "bootstrap-sha": "074315f84feac865f6648d294c06f6f1095d8077",
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "deps", "section": "Dependencies" },
    { "type": "docs", "section": "Documentation" }
  ],
  "packages": {
    ".": {
      "package-name": "unraid-mcp",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        { "type": "json", "path": "plugins/unraid/.claude-plugin/plugin.json", "jsonpath": "$.version" },
        { "type": "json", "path": "plugins/unraid/.codex-plugin/plugin.json", "jsonpath": "$.version" },
        { "type": "json", "path": "gemini-extension.json", "jsonpath": "$.version" }
      ]
    }
  }
}
