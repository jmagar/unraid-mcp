# syslog-mcp file-tail sources on squirts.
# Install to /etc/apparmor.d/local/usr.sbin.rsyslogd, then reload the
# rsyslogd profile with:
#   sudo apparmor_parser -r /etc/apparmor.d/usr.sbin.rsyslogd

/ r,
/mnt/ r,
/mnt/appdata/ r,
/mnt/appdata/swag/ r,
/mnt/appdata/swag/log/ r,
/mnt/appdata/swag/log/nginx/ r,
/mnt/appdata/swag/log/nginx/access.log r,
/mnt/appdata/swag/log/nginx/error.log r,
/mnt/appdata/swag/log/fail2ban/ r,
/mnt/appdata/swag/log/fail2ban/fail2ban.log r,
/mnt/appdata/authelia/ r,
/mnt/appdata/authelia/logs/ r,
/mnt/appdata/authelia/logs/authelia.log r,
/mnt/appdata/adguard/ r,
/mnt/appdata/adguard/var/ r,
/mnt/appdata/adguard/var/data/ r,
/mnt/appdata/adguard/var/data/querylog.json r,
/home/ r,
/home/jmagar/ r,
/home/jmagar/.claude/ r,
/home/jmagar/.claude/projects/ r,
/home/jmagar/.claude/projects/*/ r,
/home/jmagar/.claude/projects/*/*.jsonl r,
/home/jmagar/.codex/ r,
/home/jmagar/.codex/sessions/ r,
/home/jmagar/.codex/sessions/*/ r,
/home/jmagar/.codex/sessions/*/*/ r,
/home/jmagar/.codex/sessions/*/*/*/ r,
/home/jmagar/.codex/sessions/*/*/*/*.jsonl r,
/home/jmagar/.codex/sessions/index/ r,
/home/jmagar/.codex/sessions/index/by-dir/ r,
/home/jmagar/.codex/sessions/index/by-dir/*.jsonl r,
/home/jmagar/.gemini/ r,
/home/jmagar/.gemini/tmp/ r,
/home/jmagar/.gemini/tmp/*/ r,
/home/jmagar/.gemini/tmp/*/chats/ r,
/home/jmagar/.gemini/tmp/*/chats/session-*.json r,
