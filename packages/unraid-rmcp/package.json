{
  "name": "unraid-rmcp",
  "version": "0.2.2",
  "description": "Node launcher for the unraid-rmcp Rust MCP server and CLI binary.",
  "license": "MIT",
  "homepage": "https://github.com/jmagar/unraid-rmcp#readme",
  "repository": {
    "type": "git",
