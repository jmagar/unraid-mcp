Title="Unraid MCP"
Icon="unraid-mcp.png"
Tag="plug"
---
<?php
/*
 * Thin shell — the Vue custom element bundle is the whole UI. It POSTs to
 * include/config.php with the webGUI session cookie + this CSRF token; the
 * global auto_prepend (local_prepend.php) validates it on every POST, the
 * same enforcement every stock page relies on.
 *
 * Canonical token source is $var['csrf_token'] (populated by the page layout,
 * as in dynamix/BootParameters.page). Fall back to an absolute-path parse of
 * var.ini in case $var isn't in scope.
 */
$mcp_csrf = $var['csrf_token'] ?? '';
if ($mcp_csrf === '') {
    $mcp_csrf = @parse_ini_file('/usr/local/emhttp/state/var.ini')['csrf_token'] ?? '';
}
?>
<script>window.csrf_token = "<?= htmlspecialchars($mcp_csrf, ENT_QUOTES) ?>";</script>
<link rel="stylesheet" href="/plugins/unraid-mcp/web/unraid-mcp-settings.css">
<unraid-mcp-settings-app></unraid-mcp-settings-app>
<script type="module" src="/plugins/unraid-mcp/web/unraid-mcp-settings.js"></script>
