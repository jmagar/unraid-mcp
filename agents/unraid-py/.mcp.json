{
  "mcpServers": {
    "unraid-mcp": {
      "command": "uvx",
      "args": [
        "unraid-mcp"
      ],
      "env": {
        "UNRAID_MCP_TRANSPORT": "stdio",
        "UNRAID_API_URL": "${CLAUDE_PLUGIN_OPTION_UNRAID_API_URL}",
        "UNRAID_API_KEY": "${CLAUDE_PLUGIN_OPTION_UNRAID_API_KEY}"
      }
    }
  }
}
